---
import Base from "../layouts/Base.astro";
import { fetchReleases } from "../lib/releases";

// Fetched at build time (fail-safe → [] → GitHub fallback below).
const releases = await fetchReleases();
---
<Base title="Changelog" lang="en" description="What's new in Lisa — release notes by version.">
  <header class="page-head">
    <p class="eyebrow"><span class="rule"></span> CHANGELOG <b>· newest first</b></p>
    <h1>What’s new</h1>
    <p class="lede">
      Every Lisa release, newest first. Grab the latest from the
      <a href="/install">install page</a>, or browse
      <a href="https://github.com/oratis/LISA/releases/latest" target="_blank" rel="noopener">GitHub Releases ↗</a>.
      The Mac app checks here too — <em>Lisa ▸ About ▸ Check for Updates</em>.
    </p>
  </header>

  {releases.length === 0 ? (
    <p class="empty">
      Couldn’t load releases right now — see them on
      <a href="https://github.com/oratis/LISA/releases" target="_blank" rel="noopener">GitHub ↗</a>.
    </p>
  ) : (
    <div class="releases">
      {releases.map((r, i) => (
        <section class="console release">
          <div class="console-bar">
            <span class="dot r"></span><span class="dot y"></span><span class="dot g"></span>
            <span class="console-title">{r.tag || r.name}{r.date ? ` · ${r.date}` : ""}</span>
            {i === 0 ? <span class="console-badge">● latest</span> : null}
          </div>
          <div class="console-body">
            {r.body ? <pre class="notes">{r.body}</pre> : <p>No notes for this release.</p>}
            <p class="ghlink"><a href={r.url} target="_blank" rel="noopener">View {r.tag || "release"} on GitHub ↗</a></p>
          </div>
        </section>
      ))}
    </div>
  )}

  <style>
    .page-head h1 { margin-bottom: .4rem; }
    .lede { font-size: 1.15rem; color: var(--muted); max-width: 66ch; }
    .releases { display: grid; gap: 1.1rem; margin-top: 2.2rem; }
    .release { margin: 0; }
    .release .notes {
      margin: 0; white-space: pre-wrap; word-wrap: break-word;
      font-family: var(--mono); font-size: .84rem; line-height: 1.7; color: var(--ink);
    }
    .release .ghlink { margin: 1rem 0 0; font-family: var(--mono); font-size: .8rem; }
    .empty { max-width: 66ch; }
  </style>
</Base>
