---
import Base from "../layouts/Base.astro";
import data from "../data/moods.json";

const { styleLock, moods } = data as {
  styleLock: string;
  moods: Array<{ slug: string; category: string; hint: string; prompt: string }>;
};

// Group by category
const grouped = moods.reduce<Record<string, typeof moods>>((acc, m) => {
  (acc[m.category] ??= []).push(m);
  return acc;
}, {});

const categoryOrder = ["emotion", "activity", "weather", "festive", "outfit", "persona"];
---
<Base title="Mood Gallery" lang="en" description="All 114 of Lisa's mood portraits — pixel-art, style-locked, public prompts.">
  <header class="page-head">
    <p class="eyebrow"><span class="rule"></span> MOOD GALLERY <b>· {moods.length} portraits</b></p>
    <h1>Her many faces</h1>
    <p class="lede">
      Lisa swaps her portrait in real time during conversations with the
      <code>set_mood</code> tool — <strong>{moods.length}</strong> style-locked variants:
      same character, different state, outfit, scene, persona.
    </p>
    <p class="sub">
      Generated by <a href="https://www.volcengine.com/product/ark" target="_blank" rel="noopener">Seedream</a>,
      chroma-keyed via <code>sharp</code> to PNG with alpha. Every prompt below is public —
      copy them, derive your own catalog, run your own <code>generate-lisa-moods.ts</code>.
    </p>
  </header>

  <details class="disclosure">
    <summary>Style-lock template — the prefix every prompt shares</summary>
    <pre>{styleLock}</pre>
  </details>

  {categoryOrder.map((cat) => grouped[cat] && (
    <section class="section mood-cat">
      <p class="eyebrow"><b>{cat}</b> · {grouped[cat]!.length}</p>
      <div class="mood-grid">
        {grouped[cat]!.map((m) => (
          <figure class="mood">
            <img src={`/assets/lisa/${m.slug}.png`} alt={m.slug} loading="lazy" />
            <figcaption>
              <strong>{m.slug}</strong>
              <em>{m.hint}</em>
              <details>
                <summary>prompt</summary>
                <p>{m.prompt}</p>
              </details>
            </figcaption>
          </figure>
        ))}
      </div>
    </section>
  ))}

  <section class="section">
    <p class="eyebrow"><b>Reproduce your own</b></p>
    <pre class="repro"><code>SEEDREAM_API_KEY=ark-... \
  npx tsx scripts/generate-lisa-moods.ts</code></pre>
    <p>
      The catalog is in <a href="https://github.com/oratis/LISA/blob/main/scripts/lisa-moods.ts"><code>scripts/lisa-moods.ts</code></a>.
      Edit slugs / prompts to make a different character.
    </p>
  </section>

  <style>
    .page-head h1 { margin-bottom: .4rem; }
    .lede { font-size: 1.15rem; color: var(--muted); max-width: 64ch; }
    .sub { max-width: 68ch; font-size: .95rem; }
    .section > p:not(.eyebrow) { max-width: 72ch; }

    /* Style-lock disclosure */
    .disclosure {
      margin: 1.8rem 0 0; background: var(--panel); border: 1px solid var(--border);
      border-radius: 12px; overflow: hidden;
    }
    .disclosure summary {
      cursor: pointer; padding: .8rem 1.1rem; font-family: var(--mono); font-size: .8rem;
      color: var(--accent); list-style: none;
    }
    .disclosure summary::-webkit-details-marker { display: none; }
    .disclosure summary::before { content: "▸ "; color: var(--faint); }
    .disclosure[open] summary::before { content: "▾ "; }
    .disclosure[open] summary { border-bottom: 1px solid var(--border); }
    .disclosure pre {
      margin: 0; padding: 1rem 1.15rem; white-space: pre-wrap; word-break: break-word;
      font-family: var(--mono); font-size: .8rem; line-height: 1.65; color: var(--muted);
    }

    /* Category grids */
    .mood-cat { margin-top: 2.4rem; }
    .mood-cat .eyebrow b { text-transform: capitalize; }
    .mood-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(148px, 1fr));
      gap: .9rem; margin-top: 1rem;
    }
    .mood {
      margin: 0; background: var(--panel); border: 1px solid var(--border);
      border-radius: 12px; padding: .55rem; text-align: center;
      transition: transform .16s ease, border-color .16s;
    }
    .mood:hover { transform: translateY(-3px); border-color: var(--border-lit); }
    .mood img {
      width: 100%; aspect-ratio: 1; object-fit: contain; background: var(--bg-elev);
      border-radius: 8px; image-rendering: pixelated;
    }
    .mood figcaption { margin-top: .55rem; }
    .mood figcaption strong {
      display: block; color: var(--accent); font-family: var(--mono);
      font-size: .68rem; word-break: break-all; margin-bottom: .2rem;
    }
    .mood figcaption em { color: var(--muted); font-style: normal; font-size: .78rem; }
    .mood details { margin-top: .45rem; text-align: left; }
    .mood details summary {
      cursor: pointer; color: var(--blue); font-family: var(--mono); font-size: .7rem;
    }
    .mood details p { margin: .4rem 0 0; font-size: .74rem; color: var(--faint); line-height: 1.5; }

    /* Reproduce block */
    .repro {
      background: var(--bg-elev); border: 1px solid var(--border); border-radius: 12px;
      padding: 1rem 1.15rem; overflow-x: auto; margin: 1rem 0;
    }
    .repro code {
      font-family: var(--mono); font-size: .85rem; line-height: 1.7; color: var(--ink);
      background: none; border: 0; padding: 0; display: block; white-space: pre;
    }
  </style>
</Base>
