---
import Base from "../layouts/Base.astro";
import data from "../data/moods.json";

const { styleLock, moods } = data as {
  styleLock: string;
  moods: Array<{ slug: string; category: string; hint: string; prompt: string }>;
};

// Group by category
const grouped = moods.reduce<Record<string, typeof moods>>((acc, m) => {
  (acc[m.category] ??= []).push(m);
  return acc;
}, {});

const categoryOrder = ["emotion", "activity", "weather", "festive", "outfit", "persona"];
---
<Base title="Mood Gallery" lang="en" description="All 114 of Lisa's mood portraits — pixel-art, style-locked, public prompts.">
  <h1>Mood Gallery</h1>

  <p>
    Lisa swaps her portrait in real-time during conversations with the
    <code>set_mood</code> tool. There are <strong>{moods.length}</strong>
    style-locked variants — same character, different state, outfit, scene, persona.
  </p>

  <p class="meta">
    Generated by <a href="https://www.volcengine.com/product/ark" target="_blank" rel="noopener">Seedream</a>,
    chroma-keyed via <code>sharp</code> to PNG with alpha. All prompts below are
    public — copy them, derive your own catalog, run your own <code>generate-lisa-moods.ts</code>.
  </p>

  <details class="style-lock">
    <summary>Style-lock template (the prefix every prompt shares)</summary>
    <pre>{styleLock}</pre>
  </details>

  {categoryOrder.map((cat) => grouped[cat] && (
    <section>
      <h2>{cat} ({grouped[cat]!.length})</h2>
      <div class="grid">
        {grouped[cat]!.map((m) => (
          <figure class="mood">
            <img src={`/assets/lisa/${m.slug}.png`} alt={m.slug} loading="lazy" />
            <figcaption>
              <strong>{m.slug}</strong>
              <em>{m.hint}</em>
              <details>
                <summary>prompt</summary>
                <p>{m.prompt}</p>
              </details>
            </figcaption>
          </figure>
        ))}
      </div>
    </section>
  ))}

  <h2>Reproduce your own</h2>
  <pre><code>SEEDREAM_API_KEY=ark-... \
  npx tsx scripts/generate-lisa-moods.ts</code></pre>
  <p>
    The catalog is in <a href="https://github.com/oratis/LISA/blob/main/scripts/lisa-moods.ts"><code>scripts/lisa-moods.ts</code></a>.
    Edit slugs / prompts to make a different character.
  </p>
</Base>

<style>
  .meta { color: var(--text-dim); font-size: 17px; }
  .style-lock {
    background: var(--panel);
    border: 4px solid var(--border);
    padding: 12px 16px;
    margin: 24px 0;
    font-size: 17px;
  }
  .style-lock summary {
    cursor: pointer;
    color: var(--lisa);
    font-family: 'Press Start 2P', monospace;
    font-size: 11px;
  }
  .style-lock pre {
    margin-top: 12px;
    border: 2px solid var(--border-light);
    background: var(--bg);
    padding: 12px;
    font-size: 15px;
    white-space: pre-wrap;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 16px;
    margin: 16px 0 32px;
  }
  .mood {
    background: var(--panel);
    border: 4px solid var(--border);
    padding: 8px;
    margin: 0;
    text-align: center;
    transition: border-color .15s;
  }
  .mood:hover { border-color: var(--lisa); }
  .mood img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: contain;
    background: var(--bg);
    image-rendering: pixelated;
  }
  .mood figcaption {
    margin-top: 8px;
    font-size: 15px;
  }
  .mood figcaption strong {
    display: block;
    color: var(--lisa);
    font-family: 'Press Start 2P', monospace;
    font-size: 10px;
    margin-bottom: 4px;
    word-break: break-all;
  }
  .mood figcaption em {
    color: var(--text-dim);
    font-style: italic;
    font-size: 14px;
  }
  .mood details {
    margin-top: 8px;
    text-align: left;
    font-size: 13px;
  }
  .mood details summary {
    cursor: pointer;
    color: var(--you);
    font-size: 12px;
  }
  .mood details p {
    margin: 6px 0 0;
    font-size: 13px;
    color: var(--text-dim);
  }
</style>
